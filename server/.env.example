EXCHANGE_RATE_API_KEY=your_api_key_here

# PostgreSQL connection string
DATABASE_URL=postgresql://USERNAME:PASSWORD@localhost:5432/currency_converter_db

# Server
PORT=3002
NODE_ENV=production

# CORS — set to your production frontend URL
CLIENT_URL=https://currency-converter.martinmaina.dev
